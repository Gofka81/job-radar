# Copy to .env and fill in. .env is gitignored.

# Adzuna — free API key: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Reed — free API key: https://www.reed.co.uk/developers
REED_API_KEY=

# Telegram notifications (Phase 3) — bot token from @BotFather, chat id from your chat
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- API sync (Pi <-> PC), Phase 2 ---
# Shared secret for the HTTP API. The Pi (server) and PC (bridge) must match.
# The API is exposed publicly via cloudflared, so this gate is mandatory.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
JOB_RADAR_API_TOKEN=

# PC side only: base URL of the Pi API (your cloudflared hostname).
JOB_RADAR_API_URL=https://job-radar.example.com

# --- Docker deploy on the Pi ---
# Cloudflare Tunnel token (Zero Trust → Networks → Tunnels → your tunnel).
# Configure that tunnel's public hostname to route to http://server:8000.
TUNNEL_TOKEN=
# Optional: container timezone so the cron schedule runs in local time.
TZ=Europe/London
