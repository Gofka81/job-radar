# Copy to .env and fill in. .env is gitignored.
# On the Pi these are set as Portainer stack env vars instead of a file.

# Adzuna — free API key: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Reed — free API key: https://www.reed.co.uk/developers
REED_API_KEY=

# Telegram notifications (Phase 3) — bot token from @BotFather, chat id from your chat
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- API auth (Pi <-> PC) ---
# Shared secret for the HTTP API; the server and the PC bridge must match.
# It's reachable remotely, so this gate is mandatory.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
JOB_RADAR_API_TOKEN=

# PC side only: base URL of the Pi API (whatever host your tunnel/ingress serves).
JOB_RADAR_API_URL=https://job-radar.example.com

# --- Runtime (optional) ---
# Scan schedule (cron hour field) and timezone for the in-process scheduler.
SCAN_HOURS=7-19/2
TZ=Europe/London
