# Copy to .env and fill in. .env is gitignored.
# On the Pi these are set as Portainer stack env vars instead of a file.

# Adzuna — free API key: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Reed — free API key: https://www.reed.co.uk/developers
REED_API_KEY=

# Telegram notifications (Phase 3) — bot token from @BotFather, chat id from your chat
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- API auth (Pi <-> PC) ---
# Shared secret for the HTTP API; the server and the PC bridge must match.
# It's reachable remotely, so this gate is mandatory.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(32))"
JOB_RADAR_API_TOKEN=

# PC side only: base URL of the Pi API (whatever host your tunnel/ingress serves).
JOB_RADAR_API_URL=https://job-radar.example.com

# --- LLM triage (Stage 1 — analyze.py) ---
# Engine is config-driven (analysis.engine in config.yml). These supply its auth;
# NOTE: neither is referenced in our Python — they're read by the tool we call.
#
# claude-cli engine (DEFAULT, uses your Claude Pro subscription, no per-token $):
#   Read by the `claude` CLI we spawn (subprocess inherits this env). Mint it on a
#   logged-in machine: `claude setup-token` → paste the sk-ant-oat01-... token here.
CLAUDE_CODE_OAUTH_TOKEN=
#
# api engine (opt-in alternative, pay-per-token; read by the anthropic SDK):
#   only needed if you set analysis.engine: api in config.yml.
ANTHROPIC_API_KEY=

# --- Runtime (optional) ---
# These are only the DEFAULT SEED for the schedules — the live values are editable
# from the dashboard (Settings → Scheduling) and persisted on the volume, so you can
# retime or halt crawling/triage with no redeploy. Cron hour field; empty = that job off.
SCAN_HOURS=7-19/2       # crawler (default every 2h, 07:00–19:00)
ANALYZE_HOURS=          # LLM triage; empty = off by default. e.g. 3 = nightly, 7-19/2 = after each scan
ANALYZE_MINUTE=20       # minute the triage cron fires — after the scan (minute 0) adds new jobs
TZ=Europe/London
